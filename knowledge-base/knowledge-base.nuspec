<?xml version="1.0"?>
<package>
  <metadata>
    <id>DocumentHub.KnowledgeBase</id>
    <version>1.0.0</version>
    <title>Document Hub Knowledge Base</title>
    <authors>Document Hub</authors>
    <owners>Document Hub</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Shared Copilot agents, instructions, prompts, and skills installed under ~/.copilot/agents.</description>
    <tags>copilot agents instructions prompts skills knowledge-base</tags>
    <projectUrl>https://example.invalid/document-hub/knowledge-base</projectUrl>
  </metadata>
  <files>
    <file src="agents\**\*" target="content\knowledge-base\agents" />
    <file src="applications\**\*" target="content\knowledge-base\applications" />
    <file src="guides\**\*" target="content\knowledge-base\guides" />
    <file src="instructions\**\*" target="content\knowledge-base\instructions" />
    <file src="prompts\**\*" target="content\knowledge-base\prompts" />
    <file src="skills\**\*" target="content\knowledge-base\skills" />
    <file src="tools\**\*" target="content\knowledge-base\tools" />
    <file src="index.md" target="content\knowledge-base" />
    <file src="routing.md" target="content\knowledge-base" />
    <file src="build\install-from-nupkg.ps1" target="tools" />
  </files>
</package>
